# OpenAI API Key Configuration
# Keep your actual .env file private. It is ignored by Git.
OPENAI_API_KEY=

# Model selection for the AI Support Engineer Agent (e.g. gpt-4o-mini, gpt-4o, o1-mini, etc.)
OPENAI_MODEL=gpt-5.4-mini

# Authentication Credentials for Railway / Deployment Access
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_secure_password
JWT_SECRET_KEY=change_this_to_a_random_secret_key
